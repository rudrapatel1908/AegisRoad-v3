# ─────────────────────────────────────────────────────────────────
# AegisRoad v3.0 — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# SQLite is used by default (aegisroad.db). For PostgreSQL, set DATABASE_URL instead.
ANTHROPIC_API_KEY=sk-ant-your-key-here
HF_SPACE_URL=http://localhost:7860
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# ── Blockchain — Proof of Repair (Avalanche Fuji Testnet) ─────────
# Step-by-step setup: see README.md → "Blockchain Setup" section
#
# 1. Add Avalanche Fuji Testnet to MetaMask (Chain ID: 43113)
#    RPC: https://api.avax-test.network/ext/bc/C/rpc
#
# 2. Get free test AVAX from: https://faucet.avax.network
#
# 3. Deploy ProofOfRepair.sol on Remix IDE (https://remix.ethereum.org)
#    Contract source is in: contracts/ProofOfRepair.sol
#    Copy the deployed contract address into CONTRACT_ADDRESS below.
#
# 4. Export your wallet private key from MetaMask → Account Details
#    Paste it into PRIVATE_KEY below (keep this secret).
#
# Leave blank to run the app without blockchain features.
# The app boots normally with blockchain disabled.

AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CONTRACT_ADDRESS=
PRIVATE_KEY=
CONTRACT_ABI=[{"inputs":[{"internalType":"string","name":"_id","type":"string"},{"internalType":"string","name":"_proofHash","type":"string"}],"name":"submitProof","outputs":[],"stateMutability":"nonpayable","type":"function"}]
